{
  "expo": {
    "name": "ProSight",
    "slug": "prosight-frontend",
    "version": "1.0.0",
    "description": "Audio-first vision app for document analysis and accessibility",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prosightfrontend",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ProSight to access your camera for image capture and analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ProSight to access your photos and documents.",
          "microphone Permission": "Allow ProSight to access audio for recording."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "We need access to your camera to capture and analyze images.",
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload and analyze documents.",
        "NSPhotoLibraryAddOnlyUsageDescription": "We need permission to save photos.",
        "NSMicrophoneUsageDescription": "We need access to your microphone for audio features.",
        "NSDocumentsUsageDescription": "We need access to your documents folder.",
        "UIRequiredDeviceCapabilities": [
          "camera",
          "microphone"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.santie.prosightfrontend"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "94682acb-2b2d-43e1-8acc-67680fef9a2b"
      }
    },
    "owner": "santie"
  }
}
