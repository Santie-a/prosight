# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development                  # development | production
APP_DEBUG=false

# --- Storage ---
UPLOADS_DIR=./uploads
ML_MODELS_DIR=./ml_models
HF_HOME=./ml_models/huggingface

# --- VLM ---
VLM_PROVIDER=moondream               # moondream | (others added later)
VLM_MODEL_PATH=vikhyatk/moondream2
VLM_MODEL_REVISION=2024-08-26
VLM_DEVICE=cuda                      # cuda | cpu

# --- TTS ---
TTS_PROVIDER=kokoro                  # kokoro | (others added later)
TTS_VOICE=af_heart                   # default voice
TTS_SAMPLE_RATE=24000
TTS_DEVICE=cpu                       # kokoro runs on cpu for now

# --- CORS ---
# Comma-separated list of allowed origins
# Correct
CORS_ORIGINS=["*"]